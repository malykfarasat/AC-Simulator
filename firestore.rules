rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USER DATA ──
    // Users can ONLY read and write their own document
    match /users/{userId} {

      // Read: only the owner
      allow read: if request.auth != null
                  && request.auth.uid == userId;

      // Write: only the owner, with data validation
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && validateUserData(request.resource.data);
    }

    // ── BLOCK EVERYTHING ELSE ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ── DATA VALIDATION FUNCTION ──
function validateUserData(data) {
  // Must have required fields
  return data.keys().hasAll(['coins', 'unlockedModels', 'achievements', 'lastUpdated'])
    // Coins must be a non-negative number within sane limits
    && data.coins is number
    && data.coins >= 0
    && data.coins <= 9999999
    // Total coins earned
    && data.totalCoinsEarned is number
    && data.totalCoinsEarned >= 0
    // Unlocked models must be a list
    && data.unlockedModels is list
    && data.unlockedModels.size() <= 12
    // Achievements must be a map
    && data.achievements is map
    // Sessions
    && data.totalSessions is number
    && data.totalSessions >= 0;
}
